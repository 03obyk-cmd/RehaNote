<div class="container mt-4">

  <!-- コミュニティ詳細エリア -->
  <div class="card community-card-nonhover mb-4">
    <div class="card-body">

      <div class="d-flex align-items-center gap-2">
        <h3 class="fw-bold mb-3"><%= @community.name %></h3>
        <% if @community.user == Current.user %>
          <span class="badge bg-primary">管理者</span>
        <% end %>
      </div>
        
      <p class="text-muted"><%= @community.body %></p>

    </div>
  </div>

  <!-- ボタンエリア -->
  <div class="mb-3">
    <% if @community.user == Current.user %>
      <%= link_to "編集", edit_community_path(@community), class: "btn btn-outline-primary btn-hover" %>
      <%= link_to "削除", community_path(@community), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "btn btn-outline-danger btn-hover" %>
    <% end %>

    <% if Current.user && @community.user != Current.user %>
      <% community_user = @community.community_users.find_by(user: Current.user) %>
      <% if community_user.nil? %>
        <%= link_to "参加申請",community_community_users_path(@community), data: { turbo_method: :post }, class: "btn btn-outline-primary btn-hover" %>

        <% elsif community_user.pending? %>
          <p>承認待ちです</p>

        <% elsif community_user.approved? %>
          <%= link_to "退会", community_community_user_path(@community, community_user), data: { turbo_method: :delete }, class: "btn btn-outline-danger btn-hover" %>

        <% elsif community_user.rejected? %>
          <p>参加拒否されました</p>

      <% end %>

    <% end %>
  </div>

  <%= link_to "参加者一覧", members_community_path(@community), class: "btn btn-outline-secondary btn-hover" %>

  <!-- 投稿エリア -->
  <div class="row">
    <% @community.posts.each do |post| %>
      <div class="col-md-4 mb-4">
        <%= link_to community_post_path(@community, post), class: "text-decoration-none text-dark" do %>
          <div class="card h-100 post-card">
            <div class="card-body d-flex flex-column">

              <div class="d-flex align-items-center gap-2">
                <h5 class="card-title"><%= post.title %></h5>
                <span class="badge bg-secondary mb-2">
                  <%= I18n.t("enums.post.start_position.#{post.start_position}") %>
                </span>
              </div>

              <p class="card-text">
                <%= truncate(post.exercise_description, length: 50) %>
              </p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%= link_to "投稿する", new_community_post_path(@community), class: "btn btn-outline-primary btn-hover" %>

</div>