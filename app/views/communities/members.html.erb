<div class="container mt-4">
  <h3 class="mb-4">メンバー一覧</h3>

  <div class="row">
    <% @community.community_users.each do |cu| %>
      <% next if cu.rejected? && @community.user != Current.user %>

      <div class="col-md-6 col-lg-3 mb-3">
        <div class="card community-card-nonhover h-100">
          <div class="card-body d-flex">

            <div class="me-3">
              <%= image_tag cu.user.get_profile_image(60,60) %>
            </div>

            <div class="flex-grow-1 d-flex flex-column">
              <p class="fw-bold mb-1"><%= cu.user.name %></p>

              <div class="mb-2">
                <% if cu.user == @community.user %>
                  <span class="badge bg-primary me-1">管理者</span>
                <% end %>

                <span class="badge
                  <% if cu.approved? %>
                    bg-success
                  <% elsif cu.pending? %>
                    bg-warning text-dark
                  <% else %>
                    bg-secondary
                  <% end %>">
                  <%= I18n.t("enums.community_user.status.#{cu.status}") %>
                </span>
              </div>

              <% if @community.user == Current.user && cu.pending? %>
                <div class="d-flex gap-2">
                  <%= link_to "承認", community_user_path(cu, status: "approved"), data: { turbo_method: :patch }, class: "btn btn-outline-success btn-sm btn-hover" %>
                  <%= link_to "拒否", community_user_path(cu, status: "rejected"), data: { turbo_method: :patch }, class: "btn btn-outline-danger btn-sm btn-hover" %>
                </div>
              <% end %>

            </div>

          </div>
        </div>
      </div>

    <% end %>
  </div>
</div>