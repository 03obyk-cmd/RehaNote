<%= form_with url: community_path(community), method: :get do |f| %>
  <div class="row mb-3">
    <div class="col-md-6">
      <%= f.search_field :keyword, value: params[:keyword], placeholder: "キーワード検索", class: "form-control me-2" %>
    </div>
    <div class="col-md-3">
      <%= f.select :start_position, options_for_select( Post.start_positions.keys.map { |k| [I18n.t("enums.post.start_position.#{k}"), k] }, params[:start_position] ), { include_blank: "すべての姿勢" }, class: "form-select me-2" %>
    </div>
    <div class="col-md-3">
      <%= f.submit "検索", class: "btn btn-outline-primary btn-hover" %>
    </div>
  </div>
<% end %>