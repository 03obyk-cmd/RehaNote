<div class="container mt-5" style="max-width: 400px;">
  <div class="card form-card">
    <div class="card-body">

      <h3 class="text-center mb-4">ログイン</h3>

      <%= form_with url: session_path do |form| %>

        <div class="mb-3">
          <%= form.label "メールアドレス" %>
          <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address], class: "form-control" %>

          <%= form.label "パスワード" %>
          <%= form.password_field :password, required: true, autocomplete: "current-password", class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= form.submit "ログイン", class: "btn btn-outline-primary btn-hover" %>
        </div>

      <% end %>

      <%= link_to "パスワードを忘れた場合", new_user_path, onclick: "alert('パスワード再発行機能は未実装です。再登録をお願いします。')" %>

    </div>
  </div>
</div>
