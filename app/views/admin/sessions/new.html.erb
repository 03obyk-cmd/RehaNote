<div class="container mt-5" style="max-width: 400px;">
  <div class="card form-card">
    <div class="card-body">

      <h3 class="text-center mb-4">管理者ログイン</h3>

      <%= form_with url: admin_session_path do |f| %>

        <div class="mb-3">
          <%= f.label :email_address, "メールアドレス" %>
          <%= f.email_field :email_address, required: true, autofocus: true, class: "form-control" %>


          <%= f.label :password, "パスワード" %>
          <%= f.password_field :password, required: true, class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.submit "ログイン", class: "btn btn-outline-primary btn-hover" %>
        </div>

      <% end %>

    </div>
  </div>
</div>