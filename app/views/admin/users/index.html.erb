<div class="container mt-4">
  <h3 class="mb-4">全ユーザー一覧</h3>

  <div class="row">
    <% @users.each do |user| %>
      <div class="col-md-6 col-lg-3 mb-3">

        <div class="card h-100 shadow-sm">
          <div class="card-body">

            <h5 class="fw-bold"><%= user.name %></h5>
            <p class="text-muted small"><%= user.email_address %></p>

            <div class="d-flex justify-content-between align-items-center">
              <%= link_to "詳細", admin_user_path(user), class: "btn btn-outline-primary btn-sm btn-hover" %>
              <%= link_to "削除", admin_user_path(user), data: { turbo_method: :delete, turbo_confirm: '本当に削除しますか？' }, class: "btn btn-outline-danger btn-sm btn-hover" %>
            </div>

          </div>
        </div>

      </div>
    <% end %>
  </div>

</div>