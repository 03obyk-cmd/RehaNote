<% if posts.any? %>
  <div class="row">
    <% posts.each do |post| %>
      <div class="col-md-4 mb-4">
        <div class="card h-100 post-card-nonhover">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title"><%= post.title %></h5>
            <p class="card-text">
              <%= truncate(post.exercise_description, length: 50) %>
            </p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center mt-4">
    <p>まだ投稿がありません</p>
  </div>
<% end %>