<div class="container mt-4">
  <h3 class="mb-4">全コミュニティ一覧</h3>

  <div class="row">
    <% @communities.each do |community| %>
      <div class="col-md-6 col-lg-4 mb-3">

        <div class="card h-100 shadow-sm">
          <div class="card-body d-flex flex-column">

            <h5 class="fw-bold mb-2"><%= community.name %></h5>
            <div class="d-flex justify-content-between align-items-center mt-auto">
              <p class="text-muted small"><%= community.body %></p>
              <%= link_to "削除", admin_community_path(community), data: { turbo_method: :delete, turbo_confirm: '本当に削除しますか？' }, class: "btn btn-outline-danger btn-hover" %>
            </div>

          </div>
        </div>

      </div>
    <% end %>
  </div>
  
</div>