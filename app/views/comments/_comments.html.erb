<h5 class="mb-3">コメント（<%= @post.comments.count %>件）</h5>
<% @post.comments.each do |comment| %>
  <div class="card shadow-sm border-1 mb-3">
    <div class="card-body">

      <div class="d-flex justify-content-between mb-2">
        <span class="fw-bold"><%= comment.user.name %></span>
        <small class="text-muted">
          <%= l comment.created_at, format: :long %>
        </small>
      </div>

      <div class="mb-2">
        <%= simple_format(comment.text) %>
      </div>

      <% if comment.user == Current.user %>
        <div class="text-end">
          <%= link_to "削除", post_comment_path(@post, comment), data: { turbo_method: :delete, turbo_confirm: "削除しますか？" }, class: "btn btn-outline-danger btn-sm btn-hover" %>
        </div>
      <% end %>

    </div>
  </div>
<% end %>
