<div class="card shadow-sm border-1 mt-4 mb-5">
  <div class="card-body">
    <h6>コメントを書く</h6>
    <%= form_with model: [post, comment] do |f| %>
      <%= f.text_area :text, class: "form-control" %>
      <div class="mt-3">
        <%= f.submit "コメントする", class: "btn btn-outline-primary btn-hover" %>
      </div>
    <% end %>
  </div>
</div>
  