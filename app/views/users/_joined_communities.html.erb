<h5 class="mb-3">参加中コミュニティ</h5>

<div class="row">
  <% @user.community_users.where(status: :approved).map(&:community).each do |community| %>
    <div class="col-md-6 col-lg-4 mb-3">

      <%= link_to community_path(community), class: "text-decoration-none text-dark" do %>

        <div class="card community-card h-100">
          <div class="card-body">
            <h6 class="fw-bold"><%= community.name %></h6>

            <p class="text-muted small">
              <%= community.body %>
            </p>

            <% if community.user == Current.user %>
              <span class="badge bg-primary">管理者</span>
            <% end %>

            <span class="badge bg-success">参加中</span>
          </div>
        </div>

      <% end %>

    </div>
  <% end %>
</div>